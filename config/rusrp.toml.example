[usrp]
remote_host = "198.51.100.10"   # AllStarLink server IP
remote_port = 34001
local_port  = 32001
bind_address = "0.0.0.0"

[audio]
alsa_device     = "plughw:1,0"
input_gain_db   = 0.0           # -12.0 to +12.0 dB
output_gain_db  = 0.0
input_highpass  = false         # 250 Hz HPF — blocks CTCSS/DCS
output_highpass = false

# Leading trim: silence the first N ms after the transmission rises.
# The channel is captured immediately; this just mutes mic click or CTCSS bleedthrough.
# Output leading trim gives CTCSS decoders (~100 ms) time to open before voice arrives.
input_leading_trim_ms   = 0     # 0–260 ms, rounded to nearest 20 ms frame
output_leading_trim_ms  = 0

# Trailing trim: drop the last N ms before the transmission falls.
# Audio is time-shifted through a FIFO so the last N ms are never forwarded.
# Removes squelch-tail noise from the input stream; removes output burst on PTT drop.
input_trailing_trim_ms  = 0     # 0–260 ms, rounded to nearest 20 ms frame
output_trailing_trim_ms = 0

[logic]
hid_device         = "/dev/hidraw0"
output_active_gpio = 3          # CM119A GPIO3 (pin 13) — PTT
input_active_low   = true       # input signal is active when pulled low
output_active_low  = true       # output signal is active-low (open-collector driver)
half_duplex        = false      # true: block second direction until first releases (first-come-first-served)

[network]
jitter_buffer_ms = 60           # 40–250 ms (rounds up to nearest 20 ms frame)

[watchdog]
network_timeout_ms        = 500   # no USRP traffic → force unkey
output_active_tail_ms     = 100   # hold output_active after UNKEY
startup_output_inhibit_ms = 2000  # suppress output at boot

[logging]
level               = "info"    # debug, info, warn, error
status_interval_sec = 10
