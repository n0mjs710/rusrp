# CM108/CM119A udev rules for rusrp
#
# Install to: /etc/udev/rules.d/90-cm119a.rules
# Reload:     sudo udevadm control --reload && sudo udevadm trigger
# Then unplug and replug the device (or reboot).

# Grant the plugdev group read/write access to the hidraw device so rusrp
# can open it without running as root.
SUBSYSTEM=="hidraw", \
    ATTRS{idVendor}=="0d8c", \
    ATTRS{idProduct}=="0012", \
    GROUP="plugdev", \
    MODE="0660"

# Suppress VOLDN from being treated as KEY_VOLUMEDOWN by the input subsystem.
# Without this a continuous carrier (COS active) silently reduces system volume.
SUBSYSTEM=="input", \
    ATTRS{idVendor}=="0d8c", \
    ATTRS{idProduct}=="0012", \
    ENV{ID_INPUT_KEY}="", \
    ENV{ID_INPUT}=""
